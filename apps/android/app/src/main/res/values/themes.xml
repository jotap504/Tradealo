<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.TradealoMobile" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primaryColor</item>
        <item name="colorPrimaryVariant">@color/primaryDarkColor</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/secondaryColor</item>
        <item name="colorSecondaryVariant">@color/secondaryColor</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar styling. -->
        <item name="android:statusBarColor">@color/primaryColor</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash Screen theme. -->
    <style name="Theme.TradealoMobile.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/secondaryColor</item>
        <item name="android:statusBarColor">@color/secondaryColor</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
