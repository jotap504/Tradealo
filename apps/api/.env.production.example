# ── Base de datos (Supabase) ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
REDIS_HOST=your-upstash-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-upstash-password

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=genera-con-openssl-rand-base64-64
JWT_REFRESH_SECRET=genera-con-openssl-rand-base64-64
ADMIN_JWT_SECRET=genera-con-openssl-rand-base64-64
ADMIN_SESSION_TIMEOUT=7200

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=tu-account-id-de-cloudflare
R2_ACCESS_KEY_ID=tu-r2-access-key
R2_SECRET_ACCESS_KEY=tu-r2-secret-key
R2_KYC_BUCKET_NAME=trocalia-kyc-private
R2_PUBLIC_BUCKET_NAME=trocalia-public
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── MercadoPago ───────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-xxx
MP_WEBHOOK_SECRET=tu-webhook-secret
MP_NOTIFICATION_URL=https://trocalia-api.fly.dev/api/v1/token-packs/webhook/mercadopago

# ── App ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://trocalia.com.ar,https://www.trocalia.com.ar
NODE_ENV=production
PORT=3001

# ── Encriptación KYC ─────────────────────────────────────────────────────────
KYC_ENCRYPTION_KEY=32-bytes-en-hex-genera-con-openssl
